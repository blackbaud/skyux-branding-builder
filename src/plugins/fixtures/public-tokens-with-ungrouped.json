{
  "theme": {
    "color": {
      "$extensions": { "com.blackbaud.developer.docs": { "groupName": "Colors" } },
      "text": {
        "$extensions": { "com.blackbaud.developer.docs": { "groupName": "Text Colors" } },
        "default": {
          "$type": "color",
          "$value": "{color.text.default}",
          "$description": "The default text color.",
          "$extensions": {
            "com.blackbaud.developer.docs": { "name": "Default Text" }
          }
        }
      }
    },
    "spacing": {
      "small": {
        "$type": "dimension",
        "$value": "{rainbow.space.s}",
        "$description": "Small spacing value.",
        "$extensions": {
          "com.blackbaud.developer.docs": { "name": "Small Spacing" }
        }
      }
    }
  }
}
