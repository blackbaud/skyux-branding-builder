{
  "theme": {
    "color": {
      "$description": "All color tokens.",
      "$extensions": { "groupName": "Colors" },
      "text": {
        "$description": "Text color tokens.",
        "$extensions": { "groupName": "Text Colors" },
        "default": {
          "$type": "color",
          "$value": "{color.text.default}",
          "$description": "The default text color.",
          "$extensions": {
            "readableName": "Default Text",
            "deprecated": "--old-text-color"
          }
        }
      },
      "background": {
        "$description": "Background color tokens.",
        "$extensions": { "groupName": "Background Colors" },
        "danger": {
          "$type": "color",
          "$value": "{color.background.danger}",
          "$description": "The background color for danger elements.",
          "$extensions": {
            "readableName": "Danger Background"
          }
        }
      }
    }
  }
}
